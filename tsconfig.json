{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "outDir": "./build",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "./src",
    "paths": {
      "#settings/*": ["./settings/*"],
      "#functions/*": ["./functions/*"],
      "#services/*": ["./services/*"],
      "#controllers/*": ["./controllers/*"],
      "#database": ["./database/index.ts"],
      "#schemas/*": ["./database/schemas/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
